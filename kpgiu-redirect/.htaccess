# === Przekierowanie starej domeny kpgiu.pl -> pacud.pl ===
# Ten plik wgraj do KATALOGU GŁÓWNEGO domeny kpgiu.pl (jej osobny folder na hostingu),
# a NIE do folderu pacud.pl. Cały ruch trafiający tutaj to kpgiu.pl, więc
# przekierowujemy wszystko na pacud.pl z zachowaniem ścieżki (301 = trwałe, SEO).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^ https://pacud.pl%{REQUEST_URI} [R=301,L]
</IfModule>

# Wariant awaryjny, gdyby mod_rewrite nie był dostępny (przekierowuje na stronę
# główną, bez zachowania ścieżki). Odkomentuj tylko jeśli powyższe nie działa:
# <IfModule !mod_rewrite.c>
#   Redirect 301 / https://pacud.pl/
# </IfModule>
