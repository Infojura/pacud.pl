---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  updated?: string;
  description?: string;
}

const { title, updated, description } = Astro.props;

// Ścieżka nawigacyjna (okruszki) - pomaga wyszukiwarkom zrozumieć hierarchię
// i wyświetla breadcrumbs w wynikach.
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Strona główna', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: title, item: new URL(Astro.url.pathname, SITE.url).href },
  ],
};
---

<Layout
  title={`${title} - ${SITE.shortName}`}
  description={description}
  type="article"
  jsonLd={breadcrumb}
>
  <Header />

  <section class="legal-hero">
    <div class="container">
      <a href="/" class="legal-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Powrót na stronę główną
      </a>
      <h1>{title}</h1>
      {updated && <p class="legal-updated">Ostatnia aktualizacja: {updated}</p>}
    </div>
  </section>

  <main class="legal">
    <div class="container">
      <div class="legal-content">
        <slot />
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .legal-hero {
    background: linear-gradient(135deg, var(--color-navy), var(--color-navy-light));
    color: #fff;
    padding: 160px 0 60px;
  }

  .legal-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 24px;
    transition: color 0.2s;
  }

  .legal-back:hover {
    color: var(--color-primary);
  }

  .legal-hero h1 {
    color: #fff;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
  }

  .legal-updated {
    margin-top: 12px;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.9rem;
  }

  .legal {
    padding: 64px 0 96px;
    background: var(--color-bg);
  }

  @media (max-width: 768px) {
    .legal-hero { padding: 130px 0 48px; }
    .legal { padding: 48px 0 72px; }
  }
</style>

<style is:global>
  .legal-content {
    max-width: 820px;
    margin: 0 auto;
    color: var(--color-text);
  }

  .legal-content h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 40px 0 14px;
  }

  .legal-content h2:first-child {
    margin-top: 0;
  }

  .legal-content h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 24px 0 10px;
  }

  .legal-content p {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 14px;
  }

  .legal-content ul,
  .legal-content ol {
    margin: 0 0 16px 22px;
    padding: 0;
    list-style: revert;
  }

  .legal-content li {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 6px;
  }

  .legal-content a {
    color: var(--color-accent);
    font-weight: 500;
  }

  .legal-content a:hover {
    text-decoration: underline;
  }

  .legal-content strong {
    color: var(--color-text);
  }

  .legal-note {
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-sm);
    padding: 16px 20px;
    margin: 24px 0;
    font-size: 0.9rem;
  }

  .legal-note p {
    margin: 0;
  }
</style>
