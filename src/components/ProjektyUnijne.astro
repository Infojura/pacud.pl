---
---

<section class="projekty" id="projekty-unijne">
  <div class="container">
    <!-- Header centered -->
    <div class="projekty-header reveal">
      <span class="section-label">Dofinansowanie UE</span>
      <h2 class="section-title">Projekty unijne</h2>
      <div class="section-divider center"></div>
    </div>

    <!-- Baner z ciągiem znaków UE / RP / Województwo Śląskie (odtworzony 1:1) -->
    <div class="eu-banner reveal delay-1">
      <div class="eu-logos">
        <img src="/images/fundusze-min.jpg" alt="Fundusze Europejskie — Program Regionalny" loading="lazy" />
        <img src="/images/polska.jpg" alt="Rzeczpospolita Polska" loading="lazy" />
        <img src="/images/Logo-slaskie-kolorowe-cmyk.jpg" alt="Województwo Śląskie" loading="lazy" />
        <img src="/images/UE_EFRR_rgb-1.jpg" alt="Unia Europejska — Europejski Fundusz Rozwoju Regionalnego" loading="lazy" />
      </div>

      <div class="eu-text">
        <p class="eu-title">
          Projekt w ramach Regionalnego Programu Operacyjnego Województwa Śląskiego
          na lata 2014-2020 (Europejski Fundusz Rozwoju Regionalnego)
        </p>

        <p class="eu-block">
          <span>DZIAŁANIE</span>
          1.2. Badania, rozwój i innowacje w przedsiębiorstwach.
        </p>

        <p class="eu-block">
          <span>REALIZACJA PROJEKTU PN.</span>
          <strong>Technologie automatycznej anonimizacji danych osobowych<br />w dokumentach cyfrowych</strong>
        </p>

        <p class="eu-footer">
          Projekt dofinansowany z Regionalnego Programu Operacyjnego Województwa Śląskiego na lata 2014-2020
        </p>
      </div>
    </div>

    <!-- Content layout -->
    <div class="projekty-layout">
      <!-- Left: project info -->
      <div class="projekty-info reveal from-left">
        <div class="info-card">
          <div class="info-label">Beneficjent / Partner w Konsorcjum B+R</div>
          <p class="info-partner">z INFOJURA Sp. z o.o.</p>
          <div class="info-divider"></div>
          <p class="info-name">
            <strong>Kancelaria Prawa Gospodarczego<br />i Ubezpieczeniowego<br />Radosław Pacud</strong>
          </p>
        </div>

        <div class="stats-row">
          <div class="stat">
            <span class="stat-value">1 221 099</span>
            <span class="stat-unit">PLN</span>
            <span class="stat-label">Wydatki kwalifikowane</span>
          </div>
          <div class="stat">
            <span class="stat-value">264 391</span>
            <span class="stat-unit">PLN</span>
            <span class="stat-label">Wartość partnera</span>
          </div>
          <div class="stat">
            <span class="stat-value">118 799</span>
            <span class="stat-unit">PLN</span>
            <span class="stat-label">Dofinansowanie</span>
          </div>
        </div>

        <div class="period-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>Okres realizacji: <strong>2022-01-01 — 2023-12-31</strong></span>
        </div>
      </div>

      <!-- Right: description -->
      <div class="projekty-desc reveal from-right">
        <div class="desc-card">
          <h3>Cel projektu</h3>
          <p>
            Projekt dotyczy przeprowadzenia prac przemysłowych oraz rozwojowych celem
            stworzenia rozwiązań informatycznych umożliwiających automatyczną anonimizację
            danych osobowych (privacy by default) w zakresie przetwarzania dokumentów cyfrowych.
          </p>
        </div>
        <p class="eu-effects">
          Planowane efekty: Prace obejmują wybór algorytmów uczących się identyfikacji danych
          osobowych (machine learning), budowę prototypu aplikacji oraz jej wdrożenie w ramach
          programu IBK oraz portalu anonimizacyjnego.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .projekty {
    padding: 120px 0;
    background: var(--color-bg);
  }

  .projekty-header {
    text-align: center;
    margin-bottom: 48px;
  }

  /* Baner ze znakami dofinansowania — biała karta, wyśrodkowany układ */
  .eu-banner {
    margin-bottom: 64px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: 40px 48px;
    text-align: center;
  }

  .eu-logos {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 36px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
  }

  .eu-logos img {
    height: 84px;
    width: auto;
    object-fit: contain;
    flex: 0 0 auto;
  }

  .eu-title {
    max-width: 760px;
    margin: 0 auto;
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--color-navy);
  }

  .eu-block {
    margin-top: 26px;
    line-height: 1.6;
    color: var(--color-text-light);
  }

  .eu-block span {
    display: block;
  }

  .eu-block strong {
    display: block;
    margin-top: 4px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-navy);
  }

  .eu-footer {
    max-width: 720px;
    margin: 30px auto 0;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .projekty-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .info-card {
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    padding: 32px;
    margin-bottom: 32px;
  }

  .info-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 4px;
  }

  .info-partner {
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  .info-divider {
    width: 40px;
    height: 2px;
    background: var(--color-border);
    margin: 20px 0;
  }

  .info-name {
    color: var(--color-navy);
    font-size: 1rem;
    line-height: 1.6;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat {
    background: var(--color-bg-alt);
    border-radius: var(--radius-sm);
    padding: 20px 14px;
    text-align: center;
    transition: transform 0.2s;
  }

  .stat:hover {
    transform: translateY(-2px);
  }

  .stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.2;
  }

  .stat-unit {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .stat-label {
    display: block;
    font-size: 0.68rem;
    color: var(--color-text-light);
    margin-top: 6px;
  }

  .period-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--color-text-light);
    padding: 14px 18px;
    background: var(--color-bg-alt);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--color-primary);
  }

  .period-badge svg {
    flex-shrink: 0;
    color: var(--color-primary);
  }

  .desc-card {
    background: var(--color-navy);
    color: rgba(255,255,255,0.85);
    padding: 40px;
    border-radius: var(--radius-md);
    margin-bottom: 32px;
  }

  .desc-card h3 {
    color: #fff;
    font-size: 1.2rem;
    margin-bottom: 16px;
  }

  .desc-card p {
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .eu-effects {
    text-align: center;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 860px) {
    .projekty { padding: 80px 0; }
    .projekty-layout { grid-template-columns: 1fr; gap: 32px; }
    .stats-row { grid-template-columns: 1fr; }
    .eu-banner { margin-bottom: 40px; padding: 32px 24px; }
    .eu-logos { gap: 24px 28px; justify-content: center; }
    .desc-card { padding: 28px; }
  }

  @media (max-width: 560px) {
    .eu-logos img { height: 56px; }
    .eu-title { font-size: 1rem; }
  }
</style>
