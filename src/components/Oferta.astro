---
const services = [
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18M3 10h18M3 7l9-4 9 4M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/></svg>',
    title: 'Obsługa przedsiębiorstw oraz M&A',
    desc: 'Kompleksowa obsługa krajowych firm oraz obrotu zagranicznego w języku polskim i angielskim. Restrukturyzacja gospodarcza i doradztwo podatkowe.',
  },
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    title: 'Ubezpieczenia i odszkodowania',
    desc: 'Doradztwo dla podmiotów rynku ubezpieczeniowego. Obsługa spraw ubezpieczeniowych oraz odszkodowawczych osób fizycznych.',
  },
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>',
    title: 'IT i bezpieczeństwo danych',
    desc: 'Doradztwo prawne w projektach informatycznych. Wsparcie transformacji cyfrowej kancelarii prawnej. Dostosowanie działalności gospodarczej do RODO. Partnerstwo z Anonyme.pl (oprogramowanie do anonimizacji dokumentów, bezpiecznej wymiany informacji z GenAI).',
  },
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
    title: 'Obsługa sygnalistów',
    desc: 'Wspieramy podmioty publiczne i przedsiębiorstwa przy wdrażaniu procesów compliance w zakresie ochrony sygnalistów. Partnerstwo z Anonyme.pl (oprogramowanie do ochrony poufności i sygnalistów).',
  },
];

// Partnerzy technologiczni w zakresie RODO, sygnalistów oraz przetwarzania w AI
const partners = [
  {
    src: '/images/40data.png',
    alt: '40Data',
    label: 'Partner technologiczny RODO',
    href: 'http://www.40data.com',
    linkText: 'www.40data.com',
  },
  {
    src: '/images/anonyme_pl_logo.jpg',
    alt: 'Anonyme.pl',
    label: 'Partner technologiczny — sygnaliści, RODO, przetwarzanie w AI',
    href: 'https://anonyme.pl/',
    linkText: 'anonyme.pl',
  },
  {
    src: '/images/ibk_logo.png',
    alt: 'IBK24',
    label: 'Partner technologiczny w zakresie zarządzania Kancelarią Prawną',
    href: 'https://www.ibk24.com',
    linkText: 'www.ibk24.com',
  },
];
---

<section class="oferta" id="oferta">
  <div class="container">
    <!-- Header -->
    <div class="oferta-header reveal">
      <span class="section-label">Co robimy</span>
      <h2 class="section-title">Nasza oferta</h2>
      <div class="section-divider"></div>
    </div>

    <!-- Lead text -->
    <div class="oferta-lead reveal delay-1">
      <p>
        Posiadamy ponad 25-letnie doświadczenie w obsłudze prawnej przedsiębiorstw oraz
        podmiotów publicznych. Doradzamy w sektorze informatycznym, handlowym, budowlanym,
        gospodarki odpadami oraz gospodarki komunalnej. Wspieramy naszych klientów
        w procesach akwizycyjnych M&A, transformacjach gospodarczych i innych sprawach
        majątkowych.
      </p>
    </div>

    <!-- Services grid -->
    <div class="services-grid">
      {services.map((s, i) => (
        <div class={`service-card reveal delay-${i + 1}`}>
          <div class="service-icon" set:html={s.icon} />
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>

    <!-- RODO / AI details -->
    <div class="rodo-section reveal">
      <div class="rodo-content">
        <h3>Wsparcie w zakresie RODO oraz przetwarzania dokumentów w narzędziach AI</h3>
        <p>
          Oferujemy bieżącą pomoc prawno-informatyczną w utrzymaniu właściwego poziomu
          ochrony danych osobowych w Twojej firmie, jak również pomoc w dialogu z Urzędem Nadzoru.
        </p>
        <div class="partners-grid">
          {partners.map((p) => (
            <div class="partner-item">
              <div class="partner-logo">
                <img src={p.src} alt={p.alt} loading="lazy" />
              </div>
              <div class="partner-meta">
                <span class="partner-label">{p.label}</span>
                <a href={p.href} target="_blank" rel="noopener noreferrer">{p.linkText}</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .oferta {
    padding: 120px 0;
    background: var(--color-bg);
  }

  .oferta-header {
    margin-bottom: 24px;
  }

  .oferta-lead {
    max-width: 680px;
    margin-bottom: 72px;
  }

  .oferta-lead p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    line-height: 1.9;
  }

  /* Services grid - 2x2 layout */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-bottom: 80px;
  }

  .service-card {
    background: #fff;
    border-radius: var(--radius-md);
    padding: 40px 36px;
    border: 1px solid var(--color-border);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .service-card:hover::after {
    transform: scaleX(1);
  }

  .service-icon {
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .service-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--color-navy);
  }

  .service-card p {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  /* RODO section */
  .rodo-section {
    margin-bottom: 32px;
  }

  .rodo-content {
    background: #fff;
    border-radius: var(--radius-md);
    padding: 48px;
    border: 1px solid var(--color-border);
  }

  .rodo-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .rodo-content p {
    color: var(--color-text-light);
    line-height: 1.8;
    max-width: 600px;
    margin-bottom: 28px;
  }

  /* Partnerzy technologiczni */
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 32px;
    margin-top: 4px;
    border-top: 1px solid var(--color-border);
  }

  .partner-item {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .partner-logo {
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .partner-logo img {
    max-height: 64px;
    max-width: 160px;
    width: auto;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .partner-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text-light);
    margin-bottom: 6px;
  }

  .partner-meta a {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .partner-meta a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .oferta { padding: 80px 0; }
    .oferta-lead { margin-bottom: 48px; }
    .services-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 48px;
    }
    .service-card { padding: 32px 24px; }
    .rodo-content { padding: 32px 24px; }
    .partners-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
