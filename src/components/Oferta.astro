---
const services = [
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18M3 10h18M3 7l9-4 9 4M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/></svg>',
    title: 'Obsługa przedsiębiorstw',
    desc: 'Kompleksowa obsługa krajowych firm oraz obrotu zagranicznego w języku polskim i angielskim.',
  },
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    title: 'Ubezpieczenia i odszkodowania',
    desc: 'Obsługa spraw ubezpieczeniowych oraz odszkodowawczych osób fizycznych.',
  },
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>',
    title: 'Ochrona danych (RODO)',
    desc: 'Dostosowanie działalności gospodarczej do wymogów Ogólnego Rozporządzenia o Ochronie Danych.',
  },
  {
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
    title: 'Obsługa sygnalistów',
    desc: 'Oprogramowanie do ochrony poufności sygnalistów, anonimizacji dokumentów i bezpiecznej wymiany informacji.',
  },
];
---

<section class="oferta" id="oferta">
  <div class="container">
    <!-- Header -->
    <div class="oferta-header reveal">
      <span class="section-label">Co robimy</span>
      <h2 class="section-title">Nasza oferta</h2>
      <div class="section-divider"></div>
    </div>

    <!-- Lead text -->
    <div class="oferta-lead reveal delay-1">
      <p>
        Posiadamy wieloletnie doświadczenie w stałej bieżącej obsłudze prawnej oraz procesów
        akwizycyjnych w branży sektora informatycznego, handlowej, finansowej, budownictwa,
        gospodarki odpadami i gospodarki komunalnej.
      </p>
    </div>

    <!-- Services grid -->
    <div class="services-grid">
      {services.map((s, i) => (
        <div class={`service-card reveal delay-${i + 1}`}>
          <div class="service-icon" set:html={s.icon} />
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>

    <!-- RODO details -->
    <div class="rodo-section reveal">
      <div class="rodo-content">
        <h3>Wsparcie w zakresie RODO</h3>
        <p>
          Oferujemy bieżącą pomoc prawno-informatyczną w utrzymaniu właściwego poziomu
          ochrony danych osobowych w Twojej firmie, jak również pomoc w dialogu z Urzędem Nadzoru.
        </p>
        <div class="rodo-partner">
          <img src="/images/40data.png" alt="40Data" width="160" loading="lazy" />
          <div>
            <span class="partner-label">Partner technologiczny RODO</span>
            <a href="http://www.40data.com" target="_blank" rel="noopener noreferrer">www.40data.com</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Tech partner -->
    <div class="tech-partner reveal">
      <div class="tech-partner-inner">
        <div class="tech-partner-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </div>
        <div>
          <h4>Partner technologiczny — Whistleblowing</h4>
          <p>
            Anonimizacja dokumentów oraz przekazywanie informacji bez ujawnienia adresatów.
          </p>
          <div class="partner-links">
            <a href="https://anonyme.pl/" target="_blank" rel="noopener noreferrer">anonyme.pl</a>
            <span class="dot"></span>
            <a href="http://www.ibk24.com" target="_blank" rel="noopener noreferrer">ibk24.com</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .oferta {
    padding: 120px 0;
    background: var(--color-bg-alt);
  }

  .oferta-header {
    margin-bottom: 24px;
  }

  .oferta-lead {
    max-width: 680px;
    margin-bottom: 72px;
  }

  .oferta-lead p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    line-height: 1.9;
  }

  /* Services grid - 2x2 layout */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-bottom: 80px;
  }

  .service-card {
    background: #fff;
    border-radius: var(--radius-md);
    padding: 40px 36px;
    border: 1px solid var(--color-border);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .service-card:hover::after {
    transform: scaleX(1);
  }

  .service-icon {
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .service-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--color-navy);
  }

  .service-card p {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  /* RODO section */
  .rodo-section {
    margin-bottom: 32px;
  }

  .rodo-content {
    background: #fff;
    border-radius: var(--radius-md);
    padding: 48px;
    border: 1px solid var(--color-border);
  }

  .rodo-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .rodo-content p {
    color: var(--color-text-light);
    line-height: 1.8;
    max-width: 600px;
    margin-bottom: 28px;
  }

  .rodo-partner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .rodo-partner img {
    border-radius: var(--radius-sm);
  }

  .partner-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 4px;
  }

  .rodo-partner a {
    color: var(--color-accent);
    font-weight: 600;
  }

  .rodo-partner a:hover {
    text-decoration: underline;
  }

  /* Tech partner */
  .tech-partner {
    background: var(--color-navy);
    border-radius: var(--radius-md);
    padding: 40px 48px;
  }

  .tech-partner-inner {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .tech-partner-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(186, 154, 108, 0.15);
    border-radius: var(--radius-sm);
    color: var(--color-primary);
  }

  .tech-partner h4 {
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .tech-partner p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .partner-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .partner-links a {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .partner-links a:hover {
    text-decoration: underline;
  }

  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .oferta { padding: 80px 0; }
    .oferta-lead { margin-bottom: 48px; }
    .services-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 48px;
    }
    .service-card { padding: 32px 24px; }
    .rodo-content { padding: 32px 24px; }
    .tech-partner { padding: 28px 24px; }
    .tech-partner-inner { flex-direction: column; }
    .rodo-partner { flex-direction: column; align-items: flex-start; }
  }
</style>
