// Placeholdery okładek — podmień `title`, `subtitle` oraz `cover` na prawdziwe dane.
// Gdy podasz plik okładki, ustaw np. cover: '/images/ksiazka-1.jpg'.
const books = [
  {
    title: 'System prawa ubezpieczeń społecznych. Część ogólna',
    subtitle: 'Prawo ubezpieczeń społecznych',
    cover: '/images/ksiazka.png',
  },
  {
    title: 'Ustrój finansowy systemu ubezpieczeń społecznych',
    subtitle: 'Prawo finansowe',
    cover: '/images/ksiazka2.png',
  },
  {
    title: 'Prawne mechanizmy przekazywania środków OFE. Oceny konstytucyjno-prawne',
    subtitle: 'Prawo konstytucyjne',
    cover: '/images/ksiazka3.png',
  },
];

// Kolejne publikacje ładowane po kliknięciu „Zobacz więcej".
// Ten sam format co `books` — dopisuj: { title, subtitle, cover }.
const morePublications = [
  { title: 'Bank i agent bankowy', subtitle: 'Bankowość i prawo cywilne', cover: '/images/ksiazka4.jpg' },
  { title: 'Oczekiwanie prawne na emeryturę dożywotnią', subtitle: 'Prawo emerytalne i ubezpieczeniowe', cover: '/images/ksiazka5.jpg' },
  { title: 'Ustawa o systemie ubezpieczeń społecznych. Komentarz', subtitle: 'Rozdział 6 i Rozdział 7\nPrawo ubezpieczeń społecznych', cover: '/images/ksiazka6.jpg' },
];
---

<section class="publikacje" id="publikacje">
  <div class="container">
    <div class="publikacje-header reveal">
      <span class="section-label">Dorobek</span>
      <h2 class="section-title">Publikacje</h2>
      <div class="section-divider center"></div>
      <p class="publikacje-lead">
        Dorobek naukowy dr hab. Radosława Pacuda, prof. UE, obejmuje ponad 100 publikacji,
        w tym samodzielne monografie, monografie zbiorowe pod jego redakcją, rozdziały
        w publikacjach naukowych, artykuły naukowe, glosy do orzeczeń Sądu Najwyższego oraz
        artykuły i komentarze popularnonaukowe publikowane w prasie branżowej.
      </p>
      <p class="publikacje-lead publikacje-lead-sub">
        Publikacje przykładowe podzielone na kierunki badań poniżej — zakładki te będą aktualizowane.
      </p>
    </div>

    <div class="areas reveal delay-1">
      {areas.map((area) => (
        <details class="area">
          <summary>
            <span class="area-title">{area.title}</span>
            <svg class="area-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="area-body">
            <ul class="pub-list">
              {area.items.map((pub) => <li>{pub}</li>)}
            </ul>
          </div>
        </details>
      ))}
    </div>

    <div class="books-grid">
      {books.map((book, i) => (
        <article class={`book-card reveal delay-${i + 1}`}>
          <div class="book-cover">
            {book.cover
              ? <img src={book.cover} alt={book.title} loading="lazy" />
              : (
                <div class="book-cover-placeholder">
                  <span class="book-spine"></span>
                  <span class="book-cover-label">{book.subtitle}</span>
                  <span class="book-cover-title">{book.title}</span>
                </div>
              )}
          </div>
          <div class="book-info">
            <h3>{book.title}</h3>
            <span class="book-meta">{book.subtitle}</span>
          </div>
        </article>
      ))}
    </div>

    {morePublications.length > 0 && (
      <>
        <div class="more-pubs" id="more-pubs" hidden>
          <div class="books-grid">
            {morePublications.map((book) => (
              <article class="book-card">
                <div class="book-cover">
                  {book.cover
                    ? <img src={book.cover} alt={book.title} loading="lazy" />
                    : (
                      <div class="book-cover-placeholder">
                        <span class="book-spine"></span>
                        <span class="book-cover-label">{book.subtitle}</span>
                        <span class="book-cover-title">{book.title}</span>
                      </div>
                    )}
                </div>
                <div class="book-info">
                  <h3>{book.title}</h3>
                  <span class="book-meta">{book.subtitle}</span>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="more-toggle reveal">
          <button type="button" class="btn btn-primary" id="more-pubs-btn" aria-expanded="false" aria-controls="more-pubs">
            <span class="more-pubs-label">Zobacz więcej</span>
            <svg class="more-pubs-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>
      </>
    )}
  </div>
</section>

<script>
  const btn = document.getElementById('more-pubs-btn');
  const panel = document.getElementById('more-pubs');
  const label = btn?.querySelector('.more-pubs-label');

  btn?.addEventListener('click', () => {
    const willShow = panel?.hasAttribute('hidden');
    if (willShow) {
      panel?.removeAttribute('hidden');
      btn.setAttribute('aria-expanded', 'true');
      btn.classList.add('is-open');
      if (label) label.textContent = 'Zwiń';
    } else {
      panel?.setAttribute('hidden', '');
      btn.setAttribute('aria-expanded', 'false');
      btn.classList.remove('is-open');
      if (label) label.textContent = 'Zobacz więcej';
    }
  });
</script>

<style>
  .publikacje {
    padding: 120px 0;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
  }

  .publikacje-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .publikacje-subtitle {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .publikacje-lead {
    max-width: 640px;
    margin: 4px auto 0;
    color: var(--color-text-light);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .publikacje-lead-sub {
    margin-top: 16px;
  }

  /* Rozwijana lista dziedzin prawa */
  .areas {
    max-width: 760px;
    margin: 0 auto 72px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .area {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .area[open] {
    border-color: transparent;
    box-shadow: var(--shadow-md);
  }

  .area summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-navy);
  }

  .area summary::-webkit-details-marker {
    display: none;
  }

  .area summary:hover .area-title {
    color: var(--color-primary);
  }

  .area-chevron {
    flex-shrink: 0;
    color: var(--color-primary);
    transition: transform 0.3s ease;
  }

  .area[open] .area-chevron {
    transform: rotate(180deg);
  }

  .area-body {
    padding: 0 24px 22px;
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pub-list li {
    position: relative;
    padding-left: 20px;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-text-light);
  }

  .pub-list li::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    max-width: 960px;
    margin: 0 auto;
    align-items: start;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .book-cover {
    width: 100%;
    max-width: 220px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .book-card:hover .book-cover {
    transform: translateY(-8px) rotate(-1deg);
    box-shadow: var(--shadow-lg);
  }

  .book-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .book-cover-placeholder {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 7;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 28px 22px;
    background: linear-gradient(150deg, var(--color-navy), var(--color-navy-light));
    color: #fff;
  }

  .book-spine {
    position: absolute;
    top: 0;
    left: 14px;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--color-primary), transparent);
    opacity: 0.6;
  }

  .book-cover-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .book-cover-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    color: #fff;
  }

  .book-info {
    margin-top: 20px;
  }

  .book-info h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 4px;
  }

  .book-meta {
    font-size: 0.85rem;
    color: var(--color-text-light);
    white-space: pre-line;
  }

  /* Rozwijana sekcja kolejnych publikacji */
  .more-pubs {
    margin-top: 40px;
  }

  @media (min-width: 769px) {
    .more-pubs .books-grid {
      grid-template-columns: repeat(3, 1fr);
      max-width: 960px;
    }
  }

  .more-toggle {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  .more-pubs-chevron {
    transition: transform 0.3s ease;
  }

  #more-pubs-btn.is-open .more-pubs-chevron {
    transform: rotate(180deg);
  }

  @media (max-width: 768px) {
    .publikacje { padding: 80px 0; }
    .publikacje-header { margin-bottom: 40px; }
    .books-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      max-width: 260px;
    }
  }
</style>
