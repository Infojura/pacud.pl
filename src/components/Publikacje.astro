---
// Dziedziny prawa — do każdej pozycji zostanie dołączony osobny plik/wykaz publikacji.
// Gdy otrzymasz plik, ustaw `file: '/pliki/nazwa.pdf'` — wtedy pojawi się przycisk pobrania.
const areas = [
  { title: 'Praca | Prawo pracy | Ubezpieczenia społeczne', file: '' },
  { title: 'Finanse | Prawo finansowe', file: '' },
  { title: 'Informatyka | Prawo informatyczne | Ochrona danych osobowych', file: '' },
  { title: 'Ubezpieczenia | Prawo ubezpieczeniowe', file: '' },
  { title: 'Prawo gospodarcze | Prawo samorządowe', file: '' },
];

// Placeholdery okładek — podmień `title`, `subtitle` oraz `cover` na prawdziwe dane.
// Gdy podasz plik okładki, ustaw np. cover: '/images/ksiazka-1.jpg'.
const books = [
  {
    title: 'System prawa ubezpieczeń społecznych. Część ogólna',
    subtitle: 'Prawo pracy i ubezpieczeń społecznych',
    cover: '/images/ksiazka.png',
  },
  {
    title: 'Ustrój finansowy systemu ubezpieczeń społecznych',
    subtitle: 'Prawo finansowe',
    cover: '/images/ksiazka2.png',
  },
  {
    title: 'Prawne mechanizmy przekazywania środków OFE. Oceny konstytucyjno-prawne',
    subtitle: 'Prawo konstytucyjne',
    cover: '/images/ksiazka3.png',
  },
];

// Kolejne publikacje ładowane po kliknięciu „Zobacz więcej".
// Ten sam format co `books` — dopisuj: { title, subtitle, cover }.
// (Na razie dane testowe — powtórzone książki z okładkami.)
const morePublications = [
  { title: 'System prawa ubezpieczeń społecznych. Część ogólna', subtitle: 'Prawo pracy i ubezpieczeń społecznych', cover: '/images/ksiazka.png' },
  { title: 'Ustrój finansowy systemu ubezpieczeń społecznych', subtitle: 'Prawo finansowe', cover: '/images/ksiazka2.png' },
  { title: 'Prawne mechanizmy przekazywania środków OFE. Oceny konstytucyjno-prawne', subtitle: 'Prawo konstytucyjne', cover: '/images/ksiazka3.png' },
];
---

<section class="publikacje" id="publikacje">
  <div class="container">
    <div class="publikacje-header reveal">
      <span class="section-label">Dorobek</span>
      <h2 class="section-title">Publikacje</h2>
      <p class="publikacje-subtitle">Publikacje prof. ucz. Radosława Pacuda</p>
      <div class="section-divider center"></div>
      <p class="publikacje-lead">
        Łączymy doświadczenie z wiedzą i nauką. Dzielimy się wiedzą na kartach książek
        oraz opracowań naukowych z następujących dziedzin prawa:
      </p>
    </div>

    <div class="areas reveal delay-1">
      {areas.map((area) => (
        <details class="area">
          <summary>
            <span class="area-title">{area.title}</span>
            <svg class="area-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="area-body">
            {area.file
              ? <a class="area-file" href={area.file} target="_blank" rel="noopener noreferrer">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  Pobierz wykaz publikacji
                </a>
              : <p class="area-placeholder">Wykaz publikacji zostanie wkrótce uzupełniony.</p>}
          </div>
        </details>
      ))}
    </div>

    <div class="books-grid">
      {books.map((book, i) => (
        <article class={`book-card reveal delay-${i + 1}`}>
          <div class="book-cover">
            {book.cover
              ? <img src={book.cover} alt={book.title} loading="lazy" />
              : (
                <div class="book-cover-placeholder">
                  <span class="book-spine"></span>
                  <span class="book-cover-label">{book.subtitle}</span>
                  <span class="book-cover-title">{book.title}</span>
                </div>
              )}
          </div>
          <div class="book-info">
            <h3>{book.title}</h3>
            <span class="book-meta">{book.subtitle}</span>
          </div>
        </article>
      ))}
    </div>

    {morePublications.length > 0 && (
      <>
        <div class="more-pubs" id="more-pubs" hidden>
          <div class="books-grid">
            {morePublications.map((book) => (
              <article class="book-card">
                <div class="book-cover">
                  {book.cover
                    ? <img src={book.cover} alt={book.title} loading="lazy" />
                    : (
                      <div class="book-cover-placeholder">
                        <span class="book-spine"></span>
                        <span class="book-cover-label">{book.subtitle}</span>
                        <span class="book-cover-title">{book.title}</span>
                      </div>
                    )}
                </div>
                <div class="book-info">
                  <h3>{book.title}</h3>
                  <span class="book-meta">{book.subtitle}</span>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="more-toggle reveal">
          <button type="button" class="btn btn-primary" id="more-pubs-btn" aria-expanded="false" aria-controls="more-pubs">
            <span class="more-pubs-label">Zobacz więcej</span>
            <svg class="more-pubs-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>
      </>
    )}
  </div>
</section>

<script>
  const btn = document.getElementById('more-pubs-btn');
  const panel = document.getElementById('more-pubs');
  const label = btn?.querySelector('.more-pubs-label');

  btn?.addEventListener('click', () => {
    const willShow = panel?.hasAttribute('hidden');
    if (willShow) {
      panel?.removeAttribute('hidden');
      btn.setAttribute('aria-expanded', 'true');
      btn.classList.add('is-open');
      if (label) label.textContent = 'Zwiń';
    } else {
      panel?.setAttribute('hidden', '');
      btn.setAttribute('aria-expanded', 'false');
      btn.classList.remove('is-open');
      if (label) label.textContent = 'Zobacz więcej';
    }
  });
</script>

<style>
  .publikacje {
    padding: 120px 0;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
  }

  .publikacje-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .publikacje-subtitle {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .publikacje-lead {
    max-width: 640px;
    margin: 4px auto 0;
    color: var(--color-text-light);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  /* Rozwijana lista dziedzin prawa */
  .areas {
    max-width: 760px;
    margin: 0 auto 72px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .area {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .area[open] {
    border-color: transparent;
    box-shadow: var(--shadow-md);
  }

  .area summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-navy);
  }

  .area summary::-webkit-details-marker {
    display: none;
  }

  .area summary:hover .area-title {
    color: var(--color-primary);
  }

  .area-chevron {
    flex-shrink: 0;
    color: var(--color-primary);
    transition: transform 0.3s ease;
  }

  .area[open] .area-chevron {
    transform: rotate(180deg);
  }

  .area-body {
    padding: 0 24px 22px;
  }

  .area-placeholder {
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .area-file {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .area-file:hover {
    text-decoration: underline;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    max-width: 960px;
    margin: 0 auto;
    align-items: start;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .book-cover {
    width: 100%;
    max-width: 220px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .book-card:hover .book-cover {
    transform: translateY(-8px) rotate(-1deg);
    box-shadow: var(--shadow-lg);
  }

  .book-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .book-cover-placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 28px 22px;
    background: linear-gradient(150deg, var(--color-navy), var(--color-navy-light));
    color: #fff;
  }

  .book-spine {
    position: absolute;
    top: 0;
    left: 14px;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--color-primary), transparent);
    opacity: 0.6;
  }

  .book-cover-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .book-cover-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    color: #fff;
  }

  .book-info {
    margin-top: 20px;
  }

  .book-info h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 4px;
  }

  .book-meta {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  /* Rozwijana sekcja kolejnych publikacji */
  .more-pubs {
    margin-top: 40px;
  }

  .more-toggle {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  .more-pubs-chevron {
    transition: transform 0.3s ease;
  }

  #more-pubs-btn.is-open .more-pubs-chevron {
    transform: rotate(180deg);
  }

  @media (max-width: 768px) {
    .publikacje { padding: 80px 0; }
    .publikacje-header { margin-bottom: 40px; }
    .books-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      max-width: 260px;
    }
  }
</style>
