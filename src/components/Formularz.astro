---
// Wysyłka formularza obsługiwana przez Web3Forms (https://web3forms.com) —
// zgłoszenia trafiają na adres przypisany do klucza (ustaw: sekretariat@pacud.pl).
// 1. Wejdź na https://web3forms.com, podaj e-mail sekretariat@pacud.pl i skopiuj Access Key.
// 2. Wklej klucz poniżej w miejsce PLACEHOLDER.
const WEB3FORMS_ACCESS_KEY = 'PLACEHOLDER-WEB3FORMS-ACCESS-KEY';
---

<section class="formularz" id="formularz">
  <div class="formularz-bg"></div>
  <div class="container formularz-grid">
    <div class="formularz-info reveal from-left">
      <span class="section-label" style="color: rgba(186,154,108,0.8);">Napisz do nas</span>
      <h2 class="formularz-title">Formularz kontaktowy</h2>
      <p class="formularz-desc">
        Zostaw nam swoją wiadomość, a odpowiemy tak szybko jak to tylko będzie możliwe.
      </p>
      <div class="formularz-divider"></div>
      <div class="formularz-trust">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Poufność gwarantowana</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          <span>Odpowiedź w 24h</span>
        </div>
      </div>
    </div>

    <form class="formularz-form reveal from-right" id="kontakt-form" novalidate>
      <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
      <input type="hidden" name="subject" value="Nowe zgłoszenie z formularza — pacud.pl" />
      <input type="hidden" name="from_name" value="Formularz KPGIU Radosław Pacud" />
      <!-- Honeypot antyspamowy (ukryty przed użytkownikiem) -->
      <input type="checkbox" name="botcheck" class="hp-field" tabindex="-1" autocomplete="off" />

      <div class="form-row">
        <div class="form-group">
          <label for="imie">Imię <span class="required">*</span></label>
          <input type="text" id="imie" name="imie" placeholder="Jan" required />
        </div>
        <div class="form-group">
          <label for="nazwisko">Nazwisko <span class="required">*</span></label>
          <input type="text" id="nazwisko" name="nazwisko" placeholder="Kowalski" required />
        </div>
      </div>

      <div class="form-group">
        <label for="telefon">Telefon <span class="required">*</span></label>
        <input type="tel" id="telefon" name="telefon" placeholder="+48 ..." required />
      </div>

      <div class="form-group">
        <label for="email">E-mail <span class="required">*</span></label>
        <input type="email" id="email" name="email" placeholder="jan@example.com" required />
      </div>

      <div class="form-group">
        <label for="wiadomosc">Wiadomość <span class="required">*</span></label>
        <textarea id="wiadomosc" name="wiadomosc" rows="4" placeholder="W czym możemy pomóc?" required></textarea>
      </div>

      <div class="form-consent">
        <input type="checkbox" id="zgoda" name="zgoda" value="tak" required />
        <label for="zgoda">
          Wyrażam zgodę na przetwarzanie moich danych osobowych w celu obsługi zapytania
          oraz akceptuję <a href="/polityka-prywatnosci" target="_blank" rel="noopener noreferrer">politykę prywatności</a>.
          <span class="required">*</span>
        </label>
      </div>

      <button type="submit" class="btn btn-primary btn-submit">
        Wyślij wiadomość
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22,2 15,22 11,13 2,9"/></svg>
      </button>

      <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('kontakt-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    // Wymagana zgoda na przetwarzanie danych
    const consent = form.querySelector('#zgoda') as HTMLInputElement | null;
    if (consent && !consent.checked) {
      status.textContent = 'Aby wysłać wiadomość, zaakceptuj politykę prywatności.';
      status.className = 'form-status error';
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) submitBtn.disabled = true;
    status.textContent = 'Wysyłanie…';
    status.className = 'form-status';

    try {
      const data = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: data,
      });
      const json = await res.json();
      if (res.ok && json.success) {
        status.textContent = 'Dziękujemy! Wiadomość została wysłana. Odpowiemy tak szybko, jak to możliwe.';
        status.className = 'form-status success';
        form.reset();
      } else {
        status.textContent = 'Nie udało się wysłać wiadomości. Spróbuj ponownie lub napisz bezpośrednio na sekretariat@pacud.pl.';
        status.className = 'form-status error';
      }
    } catch {
      status.textContent = 'Błąd połączenia. Spróbuj ponownie później lub napisz na sekretariat@pacud.pl.';
      status.className = 'form-status error';
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

<style>
  .formularz {
    position: relative;
    padding: 100px 0;
    background: var(--color-navy);
    color: #fff;
    overflow: hidden;
  }

  .formularz-bg {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(186,154,108,0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .formularz-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
    align-items: center;
  }

  .formularz-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 16px;
  }

  .formularz-desc {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .formularz-divider {
    width: 40px;
    height: 2px;
    background: var(--color-primary);
    margin: 28px 0;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.88rem;
    margin-bottom: 10px;
  }

  .trust-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .formularz-form {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: 40px;
    backdrop-filter: blur(10px);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 6px;
    color: rgba(255, 255, 255, 0.75);
  }

  .required {
    color: var(--color-primary);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(255, 255, 255, 0.08);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 20px;
  }

  .form-consent input {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .form-consent label {
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
  }

  .form-consent a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .btn-submit {
    width: 100%;
    justify-content: center;
    padding: 16px 32px;
    font-size: 0.95rem;
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Honeypot — ukryty przed człowiekiem, widoczny dla botów */
  .hp-field {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .form-status {
    margin-top: 16px;
    font-size: 0.9rem;
    line-height: 1.5;
    min-height: 1.2em;
    color: rgba(255, 255, 255, 0.75);
  }

  .form-status.success {
    color: #6ee7a8;
  }

  .form-status.error {
    color: #ff9b9b;
  }

  @media (max-width: 860px) {
    .formularz-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .formularz-form {
      padding: 28px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .formularz { padding: 72px 0; }
  }
</style>
