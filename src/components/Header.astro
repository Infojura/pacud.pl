---
const navItems = [
  { label: 'Oferta', href: '/#oferta' },
  { label: 'Zaufali nam', href: '/#zaufali-nam' },
  { label: 'Zespół', href: '/#zespol' },
  { label: 'Publikacje', href: '/#publikacje' },
  { label: 'Projekty unijne', href: '/#projekty-unijne' },
  { label: 'Kontakt', href: '/#kontakt' },
  { label: 'Blog', href: '/blog', highlight: true },
];
---

<header class="header">
  <nav class="main-nav">
    <div class="container nav-inner">
      <a href="/" class="logo">
        <img class="logo-light" src="/images/logo-white.png" alt="KPGIU Radosław Pacud" height="60" />
        <img class="logo-dark" src="/images/logo.png" alt="KPGIU Radosław Pacud" height="60" />
      </a>

      <button class="mobile-toggle" aria-label="Menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-links">
        <ul>
          {navItems.map((item) => (
            <li>
              {item.highlight ? (
                <a href={item.href} class="nav-highlight">
                  <svg class="nav-laurel" viewBox="0 0 44 96" aria-hidden="true">
                    {/* Liście wygenerowane matematycznie: każdy osadzony dokładnie
                        na krzywej łodygi, obrócony wg stycznej, malejący ku szczytowi. */}
                    <g id="laurelNav" fill="currentColor">
                      <path d="M28 92 C 14 76 11 50 16 24 C 18 15 21 9 25 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(22.8 84.8) rotate(-76.6)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(22.8 84.8) rotate(11.4)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(17 71.2) rotate(-62.4) scale(0.95)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(17 71.2) rotate(25.6) scale(0.95)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14.1 55.8) rotate(-51.2) scale(0.88)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14.1 55.8) rotate(36.8) scale(0.88)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14 39.1) rotate(-42) scale(0.8)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14 39.1) rotate(46) scale(0.8)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(16.4 22.1) rotate(-32) scale(0.7)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(16.4 22.1) rotate(56) scale(0.7)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(20.4 11.1) rotate(-19.2) scale(0.58)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(20.4 11.1) rotate(68.8) scale(0.58)" />
                      <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(25 4) rotate(38.7) scale(0.62)" />
                    </g>
                  </svg>
                  <span>{item.label}</span>
                  <svg class="nav-laurel nav-laurel-flip" viewBox="0 0 44 96" aria-hidden="true"><use href="#laurelNav" /></svg>
                </a>
              ) : (
                <a href={item.href}>{item.label}</a>
              )}
            </li>
          ))}
        </ul>
        <a href="/#formularz" class="btn btn-primary nav-cta">Formularz kontaktowy</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector('.header') as HTMLElement;
  const toggle = document.querySelector('.mobile-toggle');
  const navLinks = document.querySelector('.nav-links');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  toggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
    toggle.classList.toggle('active');
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
  });

  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      navLinks?.classList.remove('open');
      toggle?.classList.remove('active');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }

  /* Białe kolory dla navbara na górze */
  .header .nav-links ul a {
    color: rgba(255, 255, 255, 0.9);
  }

  .header .nav-links ul a:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Ciemne kolory po scrollowaniu */
  .header.scrolled {
    background: rgba(255, 255, 255);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
  }

  .header.scrolled .nav-links ul a {
    color: var(--color-text);
  }

  .header.scrolled .nav-links ul a:hover {
    color: var(--color-navy);
    background: var(--color-bg-alt);
  }

  .main-nav {
    padding: 10px 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo img {
    display: block;
    height: 65px;
    width: auto;
    transition: filter 0.3s ease;
  }

  /* Logo: biała wersja na przezroczystej (niebieskiej) belce,
     kolorowa po scrollowaniu na białym tle */
  .logo .logo-dark {
    display: none;
  }

  .header.scrolled .logo .logo-light {
    display: none;
  }

  .header.scrolled .logo .logo-dark {
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .nav-links ul {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .nav-links ul a {
    padding: 8px 16px;
    font-size: 0.88rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: all 0.2s;
  }

  /* Wyróżnienie pozycji „Blog" - słowo otoczone gałązkami laurowymi
     (jak w sekcji Hero), złoty kolor, spójne na obu stanach belki. */
  .nav-links ul a.nav-highlight,
  .header.scrolled .nav-links ul a.nav-highlight {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-primary);
  }

  .nav-links ul a.nav-highlight:hover,
  .header.scrolled .nav-links ul a.nav-highlight:hover {
    color: var(--color-primary);
    background: rgba(186, 154, 108, 0.1);
  }

  .nav-laurel {
    height: 20px;
    width: auto;
    flex-shrink: 0;
  }

  .nav-laurel-flip {
    transform: scaleX(-1);
  }

  .nav-cta {
    margin-left: 10px;
    padding: 10px 24px;
    font-size: 0.8rem;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    z-index: 10;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: all 0.3s;
    transform-origin: center;
  }

  .header.scrolled .mobile-toggle span {
    background: var(--color-navy);
  }

  .mobile-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-toggle.active span:nth-child(2) {
    opacity: 0;
  }
  .mobile-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 860px) {
    .mobile-toggle { display: flex; }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #fff;
      flex-direction: column;
      padding: 16px 24px 24px;
      border-top: 1px solid var(--color-border);
      box-shadow: var(--shadow-lg);
    }

    .nav-links.open { display: flex; }

    .nav-links ul {
      flex-direction: column;
      width: 100%;
    }

    .nav-links ul a {
      display: block;
      padding: 14px 12px;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-text) !important;
    }

    .nav-links ul a:hover {
      color: var(--color-navy) !important;
      background: var(--color-bg-alt) !important;
    }

    /* Na mobile: pełna szerokość + separator jak inne pozycje, ze złotym kolorem */
    .nav-links ul a.nav-highlight {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--color-primary) !important;
      border-bottom: 1px solid var(--color-border);
      font-weight: 700;
    }

    .nav-cta {
      margin-left: 0;
      margin-top: 8px;
      width: 100%;
      justify-content: center;
    }
  }
</style>
