---
const team = [
  {
    name: 'Radosław Pacud',
    role: 'Radca prawny',
    img: '/images/radoslaw-pacud1.jpg',
    initials: 'RP',
    desc: 'Założyciel kancelarii. Specjalizuje się w prawie gospodarczym oraz ubezpieczeniowym, doradzając przedsiębiorstwom w kraju i w obrocie zagranicznym.',
  },
  {
    name: 'Artur Osuchowski',
    role: 'Radca prawny',
    img: '',
    initials: 'AO',
    desc: 'Wspiera klientów w bieżącej obsłudze prawnej przedsiębiorstw oraz w sprawach ubezpieczeniowych i odszkodowawczych.',
  },
];
---

<section class="zespol" id="zespol">
  <div class="container">
    <div class="zespol-header reveal">
      <span class="section-label">Kim jesteśmy</span>
      <h2 class="section-title">Nasz zespół</h2>
      <div class="section-divider center"></div>
    </div>

    <div class="team-grid">
      {team.map((member, i) => (
        <div class={`team-card reveal delay-${i + 1}`}>
          <div class="team-photo">
            {member.img
              ? <img src={member.img} alt={member.name} loading="lazy" />
              : <div class="team-initials"><span>{member.initials}</span></div>}
          </div>
          <div class="team-info">
            <h3>{member.name}</h3>
            <span class="team-role">{member.role}</span>
            <p>{member.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .zespol {
    padding: 120px 0;
    background: var(--color-bg);
  }

  .zespol-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    max-width: 900px;
    margin: 0 auto;
  }

  .team-card {
    background: #fff;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .team-photo {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-alt);
    overflow: hidden;
  }

  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team-card:hover .team-photo img {
    transform: scale(1.04);
  }

  .team-initials {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-navy), var(--color-navy-light));
  }

  .team-initials span {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 800;
    letter-spacing: 2px;
    background: linear-gradient(135deg, var(--color-primary), #d4b88a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .team-info {
    padding: 28px 32px 32px;
  }

  .team-info h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 4px;
  }

  .team-role {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .team-info p {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .zespol { padding: 80px 0; }
    .zespol-header { margin-bottom: 40px; }
    .team-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 420px;
    }
    .team-info { padding: 24px 24px 28px; }
  }
</style>
