---
---

<section class="hero">
  <div class="hero-bg-overlay"></div>
  <div class="hero-tint"></div>
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="hero-title-line">Profesjonalna</span>
        <span class="hero-title-line hero-title-accent">obsługa prawna</span>
        <span class="hero-title-line">Twojego biznesu</span>
      </h1>
      <p class="hero-subtitle">
        <svg class="laurel" viewBox="0 0 44 96" aria-hidden="true">
          <defs>
            <linearGradient id="laurelGold" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#e2caa0" />
              <stop offset="0.5" stop-color="#c9a978" />
              <stop offset="1" stop-color="#b0894f" />
            </linearGradient>
          </defs>
          <g id="laurelBranch" fill="url(#laurelGold)">
            <path d="M28 92 C 12 76 10 50 16 24 C 18 16 22 10 25 5" fill="none" stroke="url(#laurelGold)" stroke-width="1.6" stroke-linecap="round" />
            <path d="M0 0 C 3 -4 3 -12 0 -18 C -3 -12 -3 -4 0 0 Z" transform="translate(24 86) rotate(-40)" />
            <path d="M0 0 C 3 -4 3 -12 0 -18 C -3 -12 -3 -4 0 0 Z" transform="translate(18 72) rotate(-52)" />
            <path d="M0 0 C 3 -4 3 -12 0 -18 C -3 -12 -3 -4 0 0 Z" transform="translate(14 56) rotate(-64)" />
            <path d="M0 0 C 3 -4 3 -12 0 -18 C -3 -12 -3 -4 0 0 Z" transform="translate(13 40) rotate(-74)" />
            <path d="M0 0 C 3 -4 3 -12 0 -18 C -3 -12 -3 -4 0 0 Z" transform="translate(15 26) rotate(-84)" />
            <path d="M0 0 C 3 -4 3 -12 0 -18 C -3 -12 -3 -4 0 0 Z" transform="translate(20 14) rotate(-92)" />
            <path d="M0 0 C 2.4 -3.2 2.4 -9.6 0 -14.4 C -2.4 -9.6 -2.4 -3.2 0 0 Z" transform="translate(28 80) rotate(28)" />
            <path d="M0 0 C 2.4 -3.2 2.4 -9.6 0 -14.4 C -2.4 -9.6 -2.4 -3.2 0 0 Z" transform="translate(22 64) rotate(18)" />
            <path d="M0 0 C 2.4 -3.2 2.4 -9.6 0 -14.4 C -2.4 -9.6 -2.4 -3.2 0 0 Z" transform="translate(18 48) rotate(8)" />
            <path d="M0 0 C 2.4 -3.2 2.4 -9.6 0 -14.4 C -2.4 -9.6 -2.4 -3.2 0 0 Z" transform="translate(18 33) rotate(0)" />
            <path d="M0 0 C 2.6 -3.4 2.6 -10 0 -15 C -2.6 -10 -2.6 -3.4 0 0 Z" transform="translate(24 8) rotate(-96)" />
          </g>
        </svg>
        <span class="hero-subtitle-text">25 lat doświadczenia w branży</span>
        <svg class="laurel laurel-flip" viewBox="0 0 44 96" aria-hidden="true"><use href="#laurelBranch" /></svg>
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#kontakt">
          Skontaktuj się
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-outline" href="#oferta">Poznaj ofertę</a>
      </div>
    </div>
  </div>

  <div class="hero-badge">
    <span class="hero-badge-line">KANCELARIA PRAWA</span>
    <span class="hero-badge-sub">Gospodarczego i Ubezpieczeniowego</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: #23242a;
    overflow: hidden;
  }

  /* Zdjęcie tła na osobnej warstwie — dzięki temu delikatne odszarzenie
     (grayscale) dotyczy tylko fotografii, a nie tekstu i złotych akcentów. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url("/images/rpacud-4.jpg");
    background-repeat: no-repeat;
    background-size: cover;
    background-position: right 6%;
    filter: grayscale(12%);
  }

  /* Przyciemnienie lewej strony — neutralna szarość (bez niebieskiego),
     pod tekstem, z odsłonięciem postaci po prawej */
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      90deg,
      rgba(28, 29, 34, 0.84) 0%,
      rgba(28, 29, 34, 0.64) 32%,
      rgba(28, 29, 34, 0.28) 58%,
      rgba(28, 29, 34, 0.04) 100%
    );
  }

  /* Bardzo delikatny niebieski akcent tylko po prawej stronie */
  .hero-tint {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      transparent 55%,
      rgba(28, 134, 198, 0.09) 100%
    );
    mix-blend-mode: screen;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    min-height: 100vh;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 120px 24px;
  }

  .hero-content {
    text-align: left;
    max-width: 580px;
  }

  /* Napis w prawym dolnym rogu sekcji hero */
  .hero-badge {
    position: absolute;
    z-index: 2;
    bottom: 34px;
    right: 40px;
    text-align: right;
    animation: fadeIn 0.8s ease-out 1.3s both;
  }

  .hero-badge-line {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.5px;
  }

  .hero-badge-sub {
    display: block;
    margin-top: 2px;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .hero-title {
    color: #fff;
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 24px;
  }

  .hero-title-line {
    display: block;
    animation: fadeInUp 0.7s ease-out both;
  }

  .hero-title-line:nth-child(1) { animation-delay: 0.3s; }
  .hero-title-line:nth-child(2) { animation-delay: 0.5s; }
  .hero-title-line:nth-child(3) { animation-delay: 0.7s; }

  .hero-title-accent {
    background: linear-gradient(135deg, var(--color-primary), #d4b88a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-divider {
    text-align: left;
    padding: 4px 0;
    animation: fadeIn 0.6s ease-out 0.9s both;
  }

  .hero-divider span {
    display: inline-block;
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
  }

  .hero-subtitle {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 40px;
    animation: fadeIn 0.6s ease-out 1s both;
  }

  .hero-subtitle-text {
    padding-left: 3px;
  }

  .laurel {
    height: 42px;
    width: auto;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.3));
  }

  .laurel-flip {
    transform: scaleX(-1);
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 1.1s both;
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (max-width: 960px) {
    .hero::before {
      background-position: 68% 6%;
    }
    .hero-bg-overlay {
      background: linear-gradient(
        180deg,
        rgba(28, 29, 34, 0.70) 0%,
        rgba(28, 29, 34, 0.62) 55%,
        rgba(28, 29, 34, 0.74) 100%
      );
    }
    .hero-container {
      justify-content: center;
      min-height: 100svh;
      padding: 130px 24px 90px;
    }
    .hero-content { text-align: center; max-width: 640px; }
    .hero-badge { bottom: 22px; right: 22px; }
    .hero-badge-line { font-size: 0.9rem; }
    .hero-badge-sub { font-size: 0.68rem; letter-spacing: 1px; }
    .hero-divider { text-align: center; }
    .hero-actions { justify-content: center; }
  }

  @media (max-width: 768px) {
    .hero-subtitle { font-size: 0.9rem; letter-spacing: 2px; gap: 12px; }
    .laurel { height: 34px; }
    .hero-actions { flex-direction: column; align-items: center; }
    .hero-actions .btn { width: 100%; max-width: 280px; justify-content: center; }
  }
</style>
