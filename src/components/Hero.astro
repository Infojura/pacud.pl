<!-- Aby wyłączyć niebieską poświatę, usuń klasę "with-glow" poniżej -->
<section class="hero with-glow">
  <div class="hero-bg-overlay"></div>
  <div class="hero-glow"></div>
  <div class="hero-particles">
    <div class="particle p1"></div>
    <div class="particle p2"></div>
    <div class="particle p3"></div>
    <div class="particle p4"></div>
    <div class="particle p5"></div>
  </div>
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">Kancelaria Prawa Gospodarczego i Ubezpieczeniowego</div>
      <h1 class="hero-title">
        <span class="hero-title-line">Profesjonalna</span>
        <span class="hero-title-line hero-title-accent">obsługa prawna</span>
        <span class="hero-title-line">Twojego biznesu</span>
      </h1>
      <div class="hero-divider">
        <span></span>
      </div>
      <p class="hero-subtitle">25 lat doświadczenia w branży</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#kontakt">
          Skontaktuj się
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-outline" href="#oferta">Poznaj ofertę</a>
      </div>
    </div>
  </div>
  <div class="hero-scroll-indicator">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-navy);
    background-image: url("/images/rpacud-4.jpg");
    background-repeat: no-repeat;
    background-size: cover;
    background-position: right 6%;
    overflow: hidden;
  }

  /* Przyciemnienie lewej strony — pod tekstem, z odsłonięciem postaci po prawej */
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(1, 2, 59, 0.94) 0%,
      rgba(1, 2, 59, 0.82) 35%,
      rgba(1, 2, 59, 0.45) 60%,
      rgba(1, 2, 59, 0.12) 100%
    );
  }

  /* Niebieska poświata — aktywna tylko gdy sekcja ma klasę "with-glow" */
  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: none;
    background:
      radial-gradient(58% 52% at 50% 42%,
        rgba(28, 134, 198, 0.42) 0%,
        rgba(28, 134, 198, 0.16) 42%,
        transparent 72%);
    mix-blend-mode: screen;
  }

  .hero.with-glow .hero-glow {
    display: block;
  }

  /* Floating particles */
  .hero-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: rgba(186, 154, 108, 0.12);
  }

  .p1 { width: 300px; height: 300px; top: -80px; right: -60px; animation: float 8s ease-in-out infinite; }
  .p2 { width: 200px; height: 200px; bottom: 10%; left: -40px; animation: float 12s ease-in-out infinite reverse; }
  .p3 { width: 120px; height: 120px; top: 40%; right: 15%; animation: float 10s ease-in-out infinite 2s; }
  .p4 { width: 80px; height: 80px; bottom: 25%; right: 30%; animation: float 7s ease-in-out infinite 1s; }
  .p5 { width: 160px; height: 160px; top: 20%; left: 10%; animation: float 14s ease-in-out infinite 3s; }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(15px, -20px) scale(1.05); }
    66% { transform: translate(-10px, 10px) scale(0.95); }
  }

  .hero-container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    min-height: 100vh;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 120px 24px;
  }

  .hero-content {
    text-align: left;
    max-width: 580px;
  }

  .hero-badge {
    display: inline-block;
    padding: 8px 20px;
    border: 1px solid rgba(186, 154, 108, 0.3);
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 32px;
    animation: fadeInDown 0.8s ease-out 0.2s both;
  }

  .hero-title {
    color: #fff;
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 24px;
  }

  .hero-title-line {
    display: block;
    animation: fadeInUp 0.7s ease-out both;
  }

  .hero-title-line:nth-child(1) { animation-delay: 0.3s; }
  .hero-title-line:nth-child(2) { animation-delay: 0.5s; }
  .hero-title-line:nth-child(3) { animation-delay: 0.7s; }

  .hero-title-accent {
    background: linear-gradient(135deg, var(--color-primary), #d4b88a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-divider {
    text-align: left;
    padding: 4px 0;
    animation: fadeIn 0.6s ease-out 0.9s both;
  }

  .hero-divider span {
    display: inline-block;
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 40px;
    animation: fadeIn 0.6s ease-out 1s both;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 1.1s both;
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: fadeIn 0.6s ease-out 1.5s both;
  }

  .scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, var(--color-primary), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  @media (max-width: 960px) {
    .hero {
      background-position: 68% 6%;
    }
    .hero-bg-overlay {
      background: linear-gradient(
        180deg,
        rgba(1, 2, 59, 0.78) 0%,
        rgba(1, 2, 59, 0.72) 55%,
        rgba(1, 2, 59, 0.82) 100%
      );
    }
    .hero-container {
      justify-content: center;
      min-height: 100svh;
      padding: 130px 24px 90px;
    }
    .hero-content { text-align: center; max-width: 640px; }
    .hero-badge { margin-left: auto; margin-right: auto; }
    .hero-divider { text-align: center; }
    .hero-actions { justify-content: center; }
  }

  @media (max-width: 768px) {
    .hero-badge { font-size: 0.6rem; letter-spacing: 1.5px; }
    .hero-subtitle { font-size: 0.9rem; letter-spacing: 2px; }
    .hero-actions { flex-direction: column; align-items: center; }
    .hero-actions .btn { width: 100%; max-width: 280px; justify-content: center; }
    .hero-scroll-indicator { display: none; }
  }
</style>
