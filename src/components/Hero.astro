---
---

<section class="hero">
  <div class="hero-bg-overlay"></div>
  <div class="hero-tint"></div>
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="hero-title-line">Profesjonalna</span>
        <span class="hero-title-line hero-title-accent">obsługa prawna</span>
        <span class="hero-title-line">Twojego biznesu</span>
      </h1>
      <p class="hero-subtitle">
        <svg class="laurel" viewBox="0 0 44 96" aria-hidden="true">
          {/* Liście wygenerowane matematycznie: każdy osadzony dokładnie
              na krzywej łodygi, obrócony wg stycznej, malejący ku szczytowi. */}
          <g id="laurelBranch" fill="#ba9a6c">
            <path d="M28 92 C 14 76 11 50 16 24 C 18 15 21 9 25 4" fill="none" stroke="#ba9a6c" stroke-width="1.6" stroke-linecap="round" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(22.8 84.8) rotate(-76.6)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(22.8 84.8) rotate(11.4)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(17 71.2) rotate(-62.4) scale(0.95)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(17 71.2) rotate(25.6) scale(0.95)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14.1 55.8) rotate(-51.2) scale(0.88)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14.1 55.8) rotate(36.8) scale(0.88)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14 39.1) rotate(-42) scale(0.8)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(14 39.1) rotate(46) scale(0.8)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(16.4 22.1) rotate(-32) scale(0.7)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(16.4 22.1) rotate(56) scale(0.7)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(20.4 11.1) rotate(-19.2) scale(0.58)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(20.4 11.1) rotate(68.8) scale(0.58)" />
            <path d="M0 0 C 2.8 -4 3.2 -11 0 -18 C -3.2 -11 -2.8 -4 0 0 Z" transform="translate(25 4) rotate(38.7) scale(0.62)" />
          </g>
        </svg>
        <span class="hero-subtitle-text">25 lat doświadczenia w branży</span>
        <svg class="laurel laurel-flip" viewBox="0 0 44 96" aria-hidden="true"><use href="#laurelBranch" /></svg>
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#kontakt">
          Skontaktuj się
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-outline" href="#oferta">Poznaj ofertę</a>
      </div>
    </div>
  </div>

  <div class="hero-badge">
    <span class="hero-badge-line">KANCELARIA PRAWA</span>
    <span class="hero-badge-sub">Gospodarczego i Ubezpieczeniowego</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: #23242a;
    overflow: hidden;
  }

  /* Zdjęcie tła na osobnej warstwie - dzięki temu delikatne odszarzenie
     (grayscale) dotyczy tylko fotografii, a nie tekstu i złotych akcentów. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url("/images/rpacud-4.jpg");
    background-repeat: no-repeat;
    background-size: cover;
    background-position: right 6%;
    filter: grayscale(12%);
  }

  /* Przyciemnienie lewej strony - neutralna szarość (bez niebieskiego),
     pod tekstem, z odsłonięciem postaci po prawej */
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      90deg,
      rgba(28, 29, 34, 0.84) 0%,
      rgba(28, 29, 34, 0.64) 32%,
      rgba(28, 29, 34, 0.28) 58%,
      rgba(28, 29, 34, 0.04) 100%
    );
  }

  /* Bardzo delikatny niebieski akcent tylko po prawej stronie */
  .hero-tint {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      transparent 55%,
      rgba(28, 134, 198, 0.09) 100%
    );
    mix-blend-mode: screen;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    min-height: 100vh;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 120px 24px;
  }

  .hero-content {
    text-align: left;
    max-width: 580px;
  }

  /* Napis w prawym dolnym rogu sekcji hero */
  .hero-badge {
    position: absolute;
    z-index: 2;
    bottom: 34px;
    right: 40px;
    text-align: right;
    animation: fadeIn 0.8s ease-out 1.3s both;
  }

  .hero-badge-line {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.5px;
  }

  .hero-badge-sub {
    display: block;
    margin-top: 2px;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .hero-title {
    color: #fff;
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 24px;
  }

  .hero-title-line {
    display: block;
    animation: fadeInUp 0.7s ease-out both;
  }

  .hero-title-line:nth-child(1) { animation-delay: 0.3s; }
  .hero-title-line:nth-child(2) { animation-delay: 0.5s; }
  .hero-title-line:nth-child(3) { animation-delay: 0.7s; }

  .hero-title-accent {
    color: var(--color-primary);
  }

  .hero-subtitle {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 40px;
    animation: fadeIn 0.6s ease-out 1s both;
  }

  .hero-subtitle-text {
    padding-left: 3px;
  }

  .laurel {
    height: 42px;
    width: auto;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.3));
  }

  .laurel-flip {
    transform: scaleX(-1);
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 1.1s both;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (max-width: 960px) {
    .hero::before {
      background-position: 68% 6%;
    }
    .hero-bg-overlay {
      background: linear-gradient(
        180deg,
        rgba(28, 29, 34, 0.70) 0%,
        rgba(28, 29, 34, 0.62) 55%,
        rgba(28, 29, 34, 0.74) 100%
      );
    }
    .hero-container {
      justify-content: center;
      min-height: 100svh;
      padding: 130px 24px 90px;
    }
    .hero-content { text-align: center; max-width: 640px; }
    .hero-badge { bottom: 22px; right: 22px; }
    .hero-badge-line { font-size: 0.9rem; }
    .hero-badge-sub { font-size: 0.68rem; letter-spacing: 1px; }
    .hero-actions { justify-content: center; }
  }

  @media (max-width: 768px) {
    .hero-subtitle { font-size: 0.9rem; letter-spacing: 2px; gap: 12px; }
    .laurel { height: 34px; }
    .hero-actions { flex-direction: column; align-items: center; }
    .hero-actions .btn { width: 100%; max-width: 280px; justify-content: center; }
  }
</style>
