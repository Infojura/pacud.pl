---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Szybkie odnośniki pomagające użytkownikowi wrócić na właściwą stronę.
const links = [
  { label: 'Oferta', href: '/#oferta' },
  { label: 'Zespół', href: '/#zespol' },
  { label: 'Publikacje', href: '/#publikacje' },
  { label: 'Kontakt', href: '/#kontakt' },
];
---

<Layout
  title="Strona nie została znaleziona (404) — Kancelaria Radosław Pacud"
  description="Strona, której szukasz, nie istnieje lub została przeniesiona. Wróć na stronę główną Kancelarii Prawa Gospodarczego i Ubezpieczeniowego Radosław Pacud."
  noindex={true}
>
  <Header />

  <main class="notfound">
    <div class="notfound-bg-overlay"></div>
    <div class="container notfound-inner">
      <span class="notfound-code">404</span>
      <h1 class="notfound-title">Strona nie została znaleziona</h1>
      <p class="notfound-desc">
        Przepraszamy — strona, której szukasz, nie istnieje, została przeniesiona
        lub zmieniła adres. Skorzystaj z odnośników poniżej lub wróć na stronę główną.
      </p>

      <div class="notfound-actions">
        <a class="btn btn-primary" href="/">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Wróć na stronę główną
        </a>
        <a class="btn btn-outline" href="/#kontakt">Kontakt</a>
      </div>

      <nav class="notfound-links" aria-label="Przydatne odnośniki">
        {links.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .notfound {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 180px 0 100px;
    background-color: var(--color-navy);
    background-image: linear-gradient(135deg, var(--color-navy), var(--color-navy-light));
    overflow: hidden;
  }

  .notfound-bg-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(50% 45% at 50% 38%,
        rgba(186, 154, 108, 0.14) 0%,
        transparent 70%);
  }

  .notfound-inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }

  .notfound-code {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(6rem, 22vw, 12rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -2px;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .notfound-title {
    color: #fff;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 800;
    margin-bottom: 16px;
  }

  .notfound-desc {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 36px;
  }

  .notfound-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .notfound-links {
    display: flex;
    gap: 8px 28px;
    justify-content: center;
    flex-wrap: wrap;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .notfound-links a {
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .notfound-links a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .notfound { padding: 140px 0 72px; }
    .notfound-actions { flex-direction: column; align-items: center; }
    .notfound-actions .btn { width: 100%; max-width: 280px; justify-content: center; }
  }
</style>
