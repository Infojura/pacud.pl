---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE } from '../../consts';

// Generujemy jedną stronę na każdy artykuł (blog jest w pełni statyczny).
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormatter = new Intl.DateTimeFormat('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const formattedDate = dateFormatter.format(post.data.pubDate);

// Dane strukturalne artykułu + okruszki (SEO).
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@id': `${SITE.url}/#organizacja` },
  mainEntityOfPage: `${SITE.url}/blog/${post.id}`,
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Strona główna', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: `${SITE.url}/blog/${post.id}` },
  ],
};
---

<Layout
  title={`${post.data.title} - ${SITE.shortName}`}
  description={post.data.description}
  image={post.data.image ?? SITE.ogImage}
  type="article"
  jsonLd={[articleSchema, breadcrumb]}
>
  <Header />

  <article>
    <header class="post-hero">
      <div class="container">
        <a href="/blog" class="post-back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Wróć do bloga
        </a>
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <span>{post.data.author}</span>
          <span class="post-meta-dot">•</span>
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        </div>
      </div>
    </header>

    <div class="post-body">
      <div class="container">
        <div class="post-content">
          <Content />
        </div>
      </div>
    </div>
  </article>

  <Footer />
</Layout>

<style>
  .post-hero {
    background: linear-gradient(135deg, var(--color-navy), var(--color-navy-light));
    color: #fff;
    padding: 150px 0 56px;
  }

  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 24px;
    transition: color 0.2s;
  }

  .post-back:hover {
    color: var(--color-primary);
  }

  .post-hero h1 {
    color: #fff;
    max-width: 820px;
    font-size: clamp(1.75rem, 4vw, 2.6rem);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 18px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
  }

  .post-meta-dot {
    opacity: 0.5;
  }

  .post-body {
    padding: 64px 0 96px;
    background: var(--color-bg);
  }

  @media (max-width: 768px) {
    .post-hero { padding: 125px 0 44px; }
    .post-body { padding: 44px 0 72px; }
  }
</style>

<!-- Style treści artykułu (Markdown → HTML). Globalne, bo dotyczą znaczników z <Content />. -->
<style is:global>
  .post-content {
    max-width: 760px;
    margin: 0 auto;
    color: var(--color-text);
  }

  .post-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 44px 0 16px;
  }

  .post-content h2:first-child {
    margin-top: 0;
  }

  .post-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 32px 0 12px;
  }

  .post-content p {
    color: var(--color-text-light);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 20px;
  }

  .post-content ul,
  .post-content ol {
    margin: 0 0 22px 24px;
    padding: 0;
    list-style: revert;
  }

  .post-content li {
    color: var(--color-text-light);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 8px;
  }

  .post-content a {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: underline;
  }

  .post-content strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .post-content blockquote {
    margin: 28px 0;
    padding: 16px 24px;
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-style: italic;
  }

  .post-content blockquote p {
    margin: 0;
    color: var(--color-text);
  }

  .post-content img {
    border-radius: var(--radius-md);
    margin: 28px 0;
  }
</style>
