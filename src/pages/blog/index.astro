---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE } from '../../consts';

// Pobieramy wszystkie artykuły, odrzucamy szkice i sortujemy od najnowszego.
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Formatowanie daty po polsku (np. „24 czerwca 2026").
const dateFormatter = new Intl.DateTimeFormat('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Okruszki (breadcrumbs) dla wyszukiwarek.
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Strona główna', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog` },
  ],
};
---

<Layout
  title={`Blog - ${SITE.shortName}`}
  description="Artykuły i komentarze prawne kancelarii Radosława Pacuda - prawo gospodarcze, ochrona sygnalistów, RODO, ubezpieczenia i doradztwo IT."
  type="article"
  jsonLd={breadcrumb}
>
  <Header />

  <section class="blog-hero">
    <div class="container">
      <span class="section-label" style="color: rgba(186,154,108,0.9);">Wiedza</span>
      <h1>Blog</h1>
      <p class="blog-hero-desc">
        Komentarze i praktyczne wskazówki z zakresu prawa gospodarczego, ochrony sygnalistów,
        RODO oraz nowych technologii.
      </p>
    </div>
  </section>

  <main class="blog-list">
    <div class="container">
      {posts.length === 0 ? (
        <p class="blog-empty">Wkrótce pojawią się tutaj pierwsze artykuły.</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post, i) => (
            <a href={`/blog/${post.id}`} class={`blog-card reveal delay-${(i % 3) + 1}`}>
              {post.data.image && (
                <div class="blog-card-media">
                  <img src={post.data.image} alt={post.data.title} loading="lazy" width="640" height="336" />
                  {post.data.category && <span class="blog-card-tag">{post.data.category}</span>}
                </div>
              )}
              <div class="blog-card-body">
                {!post.data.image && post.data.category && (
                  <span class="blog-card-tag blog-card-tag-inline">{post.data.category}</span>
                )}
                <h2 class="blog-card-title">{post.data.title}</h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <div class="blog-card-footer">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {dateFormatter.format(post.data.pubDate)}
                  </time>
                  <span class="blog-card-more">
                    Czytaj więcej
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .blog-hero {
    background: linear-gradient(135deg, var(--color-navy), var(--color-navy-light));
    color: #fff;
    padding: 160px 0 64px;
  }

  .blog-hero h1 {
    color: #fff;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 16px;
  }

  .blog-hero-desc {
    max-width: 600px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .blog-list {
    padding: 72px 0 96px;
    background: var(--color-bg);
  }

  .blog-empty {
    text-align: center;
    color: var(--color-text-light);
    font-size: 1.05rem;
    padding: 40px 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.35s;
  }

  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  /* Obraz wyróżniający na górze kafelka (stały format 40:21, jak OG). */
  .blog-card-media {
    position: relative;
    aspect-ratio: 40 / 21;
    overflow: hidden;
    background: var(--color-navy);
  }

  .blog-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blog-card:hover .blog-card-media img {
    transform: scale(1.04);
  }

  .blog-card-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 28px 32px 32px;
  }

  .blog-card-tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
    background: rgba(1, 2, 59, 0.72);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    padding: 6px 14px;
    border-radius: 50px;
  }

  /* Etykieta nałożona na obraz (lewy górny róg). */
  .blog-card-media .blog-card-tag {
    position: absolute;
    top: 16px;
    left: 16px;
  }

  /* Wariant bez obrazu - etykieta w treści, w kolorystyce marki. */
  .blog-card-tag-inline {
    align-self: flex-start;
    color: var(--color-primary);
    background: rgba(186, 154, 108, 0.1);
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    margin-bottom: 18px;
  }

  .blog-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.35;
    margin-bottom: 12px;
  }

  .blog-card-desc {
    color: var(--color-text-light);
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-top: 18px;
    border-top: 1px solid var(--color-border);
    font-size: 0.82rem;
  }

  .blog-card-footer time {
    color: var(--color-text-light);
  }

  .blog-card-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-accent);
    font-weight: 600;
    transition: gap 0.2s;
  }

  .blog-card:hover .blog-card-more {
    gap: 10px;
  }

  @media (max-width: 768px) {
    .blog-hero { padding: 130px 0 48px; }
    .blog-list { padding: 48px 0 72px; }
    .blog-grid { grid-template-columns: 1fr; gap: 20px; }
    .blog-card-body { padding: 24px 26px 28px; }
  }
</style>
