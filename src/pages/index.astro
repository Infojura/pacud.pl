---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Oferta from '../components/Oferta.astro';
import ProjektyUnijne from '../components/ProjektyUnijne.astro';
import ZaufaliNam from '../components/ZaufaliNam.astro';
import Zespol from '../components/Zespol.astro';
import Publikacje from '../components/Publikacje.astro';
import Kontakt from '../components/Kontakt.astro';
import Formularz from '../components/Formularz.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

// Schemat WebSite - powiązanie strony z marką w grafach wiedzy wyszukiwarek.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#serwis`,
  url: SITE.url,
  name: SITE.shortName,
  inLanguage: SITE.lang,
  publisher: { '@id': `${SITE.url}/#organizacja` },
};
---

<Layout
  title="Kancelaria Prawa Gospodarczego i Ubezpieczeniowego Radosław Pacud - Częstochowa"
  description="Kancelaria radcy prawnego Radosława Pacuda w Częstochowie. Obsługa prawna przedsiębiorstw, M&A, prawo ubezpieczeniowe, RODO, ochrona sygnalistów i doradztwo IT. Ponad 25 lat doświadczenia, po polsku i angielsku."
  jsonLd={websiteSchema}
>
  <Header />
  <Hero />
  <Oferta />
  <ZaufaliNam />
  <Zespol />
  <Publikacje />
  <ProjektyUnijne />
  <Kontakt />
  <Formularz />
  <Footer />
</Layout>
